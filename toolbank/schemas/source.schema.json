{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/asshat1981ar/1/toolbank/schemas/source.schema.json",
  "title": "HarvestSource",
  "description": "Schema for a seed source entry in config/sources.yaml",
  "type": "object",
  "required": ["name", "seed_urls"],
  "properties": {
    "name": { "type": "string" },
    "seed_urls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "minItems": 1
    },
    "priority": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "default": "medium"
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "max_pages": { "type": "integer", "default": 20 },
    "enabled": { "type": "boolean", "default": true }
  }
}
