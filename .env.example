# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# LLM extraction (optional — enables docs_extractor.py)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# GitHub tools + higher crawl rate limit (optional)
GITHUB_TOKEN=ghp_...

# Stripe tools (optional — required to execute stripe.* tools)
STRIPE_API_KEY=sk_test_...

# Toolbank API (Next.js — leave blank to use relative /api paths)
NEXT_PUBLIC_API_URL=

# FastMCP execute server (used by Next.js API routes as proxy target)
EXECUTE_SERVER_URL=http://localhost:8765
